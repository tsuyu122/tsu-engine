# tsuEngine — Light Baking Demo Scene
# Realistic PBR materials + architectural room ready for baking.
# Open Room Editor (Maze tab > BakeDemo > Showcase Room), hit Bake,
# and compare the before/after lighting.

# ========================
# FOG — subtle depth haze
# ========================
[fog]
type    = 2
color   = 0.50 0.55 0.65
density = 0.012

# ========================
# SKY — late-afternoon sun
# ========================
[sky]
enabled   = true
zenith    = 0.06 0.18 0.60
horizon   = 0.55 0.72 0.95
ground    = 0.22 0.18 0.14
sun_dir   = 0.40 0.75 0.30
sun_col   = 1.50 1.30 0.95
sun_size  = 0.025
sun_bloom = 0.14

# ========================
# POST-PROCESSING
# ========================
[postprocess]
enabled          = true
bloom            = true
bloom_threshold  = 0.70
bloom_intensity  = 0.50
bloom_radius     = 1.60
vignette         = true
vig_radius       = 0.72
vig_strength     = 0.50
grain            = false
grain_strength   = 0.03
chroma           = true
chroma_strength  = 0.002
color_grade      = true
exposure         = 1.15
saturation       = 1.10
contrast         = 1.08
brightness       = 0.00
sharpen          = true
sharpen_strength = 0.25
lens_distort     = false
lens_strength    = 0.00
sepia            = false
posterize        = false
scanlines        = false
pixelate         = false

# ========================
# PBR MATERIALS
# ========================

[material]
mat_index  = 0
mat_name   = Brick Wall
mat_color  = 1.0 1.0 1.0
mat_albedo = assets/textures/brick/albedo.jpg
mat_normal = assets/textures/brick/normal.jpg
mat_roughness_tex = assets/textures/brick/roughness.jpg
mat_ao     = assets/textures/brick/ao.jpg
mat_roughness  = 0.80
mat_metallic   = 0.00
mat_tiling_x   = 2.0
mat_tiling_y   = 2.0
mat_world_uv   = true

[material]
mat_index  = 1
mat_name   = Wood Floor
mat_color  = 1.0 1.0 1.0
mat_albedo = assets/textures/wood/albedo.jpg
mat_normal = assets/textures/wood/normal.jpg
mat_roughness_tex = assets/textures/wood/roughness.jpg
mat_ao     = assets/textures/wood/ao.jpg
mat_roughness  = 0.55
mat_metallic   = 0.00
mat_tiling_x   = 3.0
mat_tiling_y   = 3.0
mat_world_uv   = true

[material]
mat_index  = 2
mat_name   = Concrete
mat_color  = 1.0 1.0 1.0
mat_albedo = assets/textures/concrete/albedo.jpg
mat_normal = assets/textures/concrete/normal.jpg
mat_roughness_tex = assets/textures/concrete/roughness.jpg
mat_ao     = assets/textures/concrete/ao.jpg
mat_roughness  = 0.85
mat_metallic   = 0.00
mat_tiling_x   = 2.0
mat_tiling_y   = 2.0
mat_world_uv   = true

[material]
mat_index  = 3
mat_name   = Rusty Metal
mat_color  = 1.0 1.0 1.0
mat_albedo = assets/textures/metal/albedo.jpg
mat_normal = assets/textures/metal/normal.jpg
mat_roughness_tex = assets/textures/metal/roughness.jpg
mat_roughness  = 0.60
mat_metallic   = 0.85
mat_tiling_x   = 1.0
mat_tiling_y   = 1.0
mat_world_uv   = true

# ========================
# GAME CAMERA
# ========================
[entity]
name     = Game Camera
type     = game_camera
fov      = 60
position = 0 2.5 10
yaw      = -90.0
pitch    = -8.0

# ========================
# LIGHTS
# ========================

# Directional sun (main shadow caster)
[entity]
name            = Sun
type            = cube
position        = 10 15 5
rotation        = 45 -30 0
scale           = 0.25 0.25 0.25
color           = #FFE8B0
light           = true
light_type      = directional
light_color     = 1.0 0.95 0.85
light_temp      = 5500
light_intensity = 3.0

# Warm point light (left side)
[entity]
name            = Warm Light
type            = sphere
position        = -3 3.0 0
scale           = 0.15 0.15 0.15
color           = #FFC040
light           = true
light_type      = point
light_color     = 1.0 0.80 0.45
light_temp      = 3200
light_intensity = 5.0
light_range     = 12.0

# Cool point light (right side)
[entity]
name            = Cool Light
type            = sphere
position        = 4 3.0 0
scale           = 0.15 0.15 0.15
color           = #6090FF
light           = true
light_type      = point
light_color     = 0.55 0.70 1.0
light_temp      = 9000
light_intensity = 4.0
light_range     = 12.0

# Spot light (dramatic beam on metal sphere)
[entity]
name            = Spot Beam
type            = cube
position        = 5 5.0 0.5
rotation        = 65 -15 0
scale           = 0.12 0.12 0.12
color           = #FFFFA0
light           = true
light_type      = spot
light_color     = 1.0 0.98 0.85
light_intensity = 10.0
light_range     = 14.0
light_inner     = 10.0
light_outer     = 28.0

# ========================
# GROUND + SHOWCASE OBJECTS
# ========================

# Large ground — concrete
[entity]
name            = Ground
type            = cube
position        = 0 -0.05 0
scale           = 30 0.10 30
color           = #FFFFFF
entity_material = 2

# --- BRICK WALL (back wall behind objects) ---
[entity]
name            = Brick Wall
type            = cube
position        = 0 2.0 -3
scale           = 14 4.0 0.4
color           = #FFFFFF
entity_material = 0

# --- BRICK PILLAR LEFT ---
[entity]
name            = Brick Pillar L
