position        = -5 2.0 -2
scale           = 1.2 4.0 1.2
color           = #FFFFFF
entity_material = 0

# --- BRICK PILLAR RIGHT ---
[entity]
name            = Brick Pillar R
type            = cylinder
position        = 5 2.0 -2
scale           = 1.2 4.0 1.2
color           = #FFFFFF
entity_material = 0

# --- WOOD FLOOR PLATFORM ---
[entity]
name            = Wood Platform
type            = cube
position        = 0 0.1 0
scale           = 10 0.15 8
color           = #FFFFFF
entity_material = 1

# --- WOOD PEDESTAL 1 ---
[entity]
name            = Pedestal Left
type            = cube
position        = -3 0.5 0
scale           = 1.2 0.8 1.2
color           = #FFFFFF
entity_material = 1

# --- WOOD PEDESTAL 2 ---
[entity]
name            = Pedestal Center
type            = cube
position        = 0 0.5 0
scale           = 1.2 0.8 1.2
color           = #FFFFFF
entity_material = 1

# --- WOOD PEDESTAL 3 ---
[entity]
name            = Pedestal Right
type            = cube
position        = 3 0.5 0
scale           = 1.2 0.8 1.2
color           = #FFFFFF
entity_material = 1

# --- METAL SPHERE (on left pedestal) ---
[entity]
name            = Metal Sphere
type            = sphere
position        = -3 1.3 0
scale           = 0.8 0.8 0.8
color           = #FFFFFF
entity_material = 3

# --- CONCRETE SPHERE (on center pedestal) ---
[entity]
name            = Concrete Sphere
type            = sphere
position        = 0 1.3 0
scale           = 0.8 0.8 0.8
color           = #FFFFFF
entity_material = 2

# --- BRICK CUBE (on right pedestal) ---  
[entity]
name            = Brick Cube
type            = cube
position        = 3 1.3 0
rotation        = 0 25 0
scale           = 0.7 0.7 0.7
color           = #FFFFFF
entity_material = 0

# --- L-SHAPED CONCRETE WALL (shadow caster) ---
[entity]
name            = Wall Segment A
type            = cube
position        = -6 1.5 2
scale           = 0.3 3.0 5.0
color           = #FFFFFF
entity_material = 2

[entity]
name            = Wall Segment B
type            = cube
position        = -4.5 1.5 4.2
scale           = 3.3 3.0 0.3
color           = #FFFFFF
entity_material = 2

# --- METAL CRATE (on the floor, casts shadow) ---
[entity]
name            = Metal Crate
type            = cube
position        = 2 0.5 3
rotation        = 0 35 0
scale           = 1.0 1.0 1.0
color           = #FFFFFF
entity_material = 3

# --- CONCRETE CYLINDER ---
[entity]
name            = Concrete Column
type            = cylinder
position        = -1 1.0 3
scale           = 0.6 2.0 0.6
color           = #FFFFFF
entity_material = 2

# ========================
# ROOM SET — for light bake demo
# ========================
[roomset]
name = BakeDemo

[room]
name   = Showcase Room
rarity = 1.0

# --- FLOOR layer (y=0): 7x7 grid ---
block = 0 0 0
block = 1 0 0
block = 2 0 0
block = 3 0 0
block = 4 0 0
block = 5 0 0
block = 6 0 0
block = 0 0 1
block = 1 0 1
block = 2 0 1
block = 3 0 1
block = 4 0 1
block = 5 0 1
block = 6 0 1
block = 0 0 2
block = 1 0 2
block = 2 0 2
block = 3 0 2
block = 4 0 2
block = 5 0 2
block = 6 0 2
block = 0 0 3
block = 1 0 3
block = 2 0 3
block = 3 0 3
block = 4 0 3
block = 5 0 3
block = 6 0 3
block = 0 0 4
block = 1 0 4
block = 2 0 4
block = 3 0 4
block = 4 0 4
block = 5 0 4
block = 6 0 4
block = 0 0 5
block = 1 0 5
block = 2 0 5
block = 3 0 5
block = 4 0 5
block = 5 0 5
block = 6 0 5
block = 0 0 6
block = 1 0 6
block = 2 0 6
block = 3 0 6
block = 4 0 6
block = 5 0 6
block = 6 0 6

# --- WALLS layer 1 (y=1): perimeter ---
# North wall (z=0)
block = 0 1 0
block = 1 1 0
block = 2 1 0
block = 3 1 0
block = 4 1 0
block = 5 1 0
block = 6 1 0
# South wall (z=6)
block = 0 1 6
block = 1 1 6
block = 2 1 6
block = 3 1 6
block = 4 1 6
block = 5 1 6
block = 6 1 6
# West wall (x=0, z=1..5)
block = 0 1 1
block = 0 1 2
block = 0 1 3
block = 0 1 4
block = 0 1 5
# East wall (x=6, z=1..5)
block = 6 1 1
block = 6 1 2
block = 6 1 3
block = 6 1 4
block = 6 1 5

# --- INTERNAL L-WALL (shadow caster) ---
# Vertical segment x=3, z=1..4
block = 3 1 1
block = 3 1 2
block = 3 1 3
block = 3 1 4
# Horizontal segment x=3..5, z=4
block = 4 1 4
block = 5 1 4

# --- PILLARS (y=1 + y=2) ---
block = 1 1 1
block = 1 2 1
block = 5 1 5
block = 5 2 5

# --- WALLS layer 2 (y=2): perimeter top ---
# North
block = 0 2 0
block = 1 2 0
block = 2 2 0
block = 3 2 0
block = 4 2 0
block = 5 2 0
block = 6 2 0
# South
block = 0 2 6
block = 1 2 6
block = 2 2 6
block = 3 2 6
block = 4 2 6
block = 5 2 6
block = 6 2 6
# West
block = 0 2 1
block = 0 2 2
block = 0 2 3
block = 0 2 4
block = 0 2 5
# East
block = 6 2 1
block = 6 2 2
block = 6 2 3
block = 6 2 4
block = 6 2 5

# --- DOOR SLOTS ---
# Doorway opening facing +Z on north wall at x=3
door = 3 0 1 2
# Doorway opening facing -X on east wall at z=3
door = 6 3 1 1

# --- INTERIOR OBJECTS ---
# Wooden crate in left chamber
interior_name     = Crate
interior_mesh     = cube
interior_material = Wood Floor
interior_pos      = 1.5 0.5 3.0
interior_rot      = 0 25 0
interior_scl      = 0.7 0.7 0.7
interior_end      = 1

# Metal barrel in right chamber
interior_name     = Barrel
interior_mesh     = cylinder
interior_material = Rusty Metal
interior_pos      = 5.0 0.4 2.0
interior_rot      = 0 0 0
interior_scl      = 0.5 0.8 0.5
interior_end      = 1

# Brick pedestal in right chamber
interior_name     = Pedestal
interior_mesh     = cube
interior_material = Brick Wall
interior_pos      = 4.5 0.25 5.5
interior_rot      = 0 0 0
interior_scl      = 0.8 0.5 0.8
interior_end      = 1

# Artifact on pedestal
interior_name     = Artifact
interior_mesh     = sphere
interior_material = Rusty Metal
interior_pos      = 4.5 0.75 5.5
interior_rot      = 0 0 0
interior_scl      = 0.35 0.35 0.35
interior_end      = 1

# Small concrete block in left chamber
interior_name     = Rubble
interior_mesh     = cube
interior_material = Concrete
interior_pos      = 2.0 0.2 5.0
interior_rot      = 0 35 0
interior_scl      = 0.4 0.4 0.6
interior_end      = 1
